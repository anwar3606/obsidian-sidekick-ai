# Set default behavior to automatically normalize line endings
* text=auto

# JavaScript files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# HTML files
*.html text eol=lf
*.htm text eol=lf

# CSS files
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf

# JSON files
*.json text eol=lf

# Config files often used with JS projects
*.config text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Ensure binaries are handled properly
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text